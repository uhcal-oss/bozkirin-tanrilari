MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1764772433}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b83a42f8f29be63479ff24c6194bf230, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogue
  conversation:
  - text: Merhaba!
    portrait: {fileID: 4806233126341278129, guid: b4515ba62d2a9ab46a9506bfd2ae340c, type: 3}
    speakerName: Yeliz
  - text: "L\xFCtfen sende bana inek deme..."
    portrait: {fileID: 1469127401526767444, guid: 61d50f809fe74f3418518af3119404c3, type: 3}
    speakerName: Nehir
  - text: "Ne? Neden b\xF6yle bi\u015Fey diyeyim ki? "
    portrait: {fileID: 4806233126341278129, guid: b4515ba62d2a9ab46a9506bfd2ae340c, type: 3}
    speakerName: Yeliz
  - text: "Herkes y\xFCz\xFCmdeki virtaligodan dolay\u0131 benle inek diye dalga
      ge\xE7iyor.."
    portrait: {fileID: 1469127401526767444, guid: 61d50f809fe74f3418518af3119404c3, type: 3}
    speakerName: Nehir
  - text: "Onlar\u0131 takma, bence gayet g\xFCzel bir g\xF6r\xFCnt\xFCn var.. Bu
      \xF6zelli\u011Fin seni daha \xF6zg\xFCn k\u0131l\u0131yor..."
    portrait: {fileID: 4806233126341278129, guid: b4515ba62d2a9ab46a9506bfd2ae340c, type: 3}
    speakerName: Yeliz
  onDialogueEnd:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 733103975}
        m_TargetAssemblyTypeName: MiniGameLauncher, Assembly-CSharp
        m_MethodName: LaunchGame
