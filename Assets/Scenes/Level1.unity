  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b83a42f8f29be63479ff24c6194bf230, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogue
  conversation:
  - text: "Cevab\u0131 buldun mu?"
    portrait: {fileID: -1323775644, guid: 30a885ca62e87834da7c2ea4faf0bb07, type: 3}
    speakerName: "G\xF6kb\xF6r\xFC"
  - text: Evet. Cevap umut.
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "*(G\xF6kb\xF6r\xFC ba\u015F\u0131n\u0131 sallar.)*"
    portrait: {fileID: -1323775644, guid: 30a885ca62e87834da7c2ea4faf0bb07, type: 3}
    speakerName: "G\xF6kb\xF6r\xFC"
  - text: "Do\u011Fru cevap. \u015Eimdi beni takip et."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: "G\xF6kb\xF6r\xFC"
  - text: "Ate\u015F Tanr\u0131s\u0131\u2019n\u0131n gizli ma\u011Faras\u0131."
    portrait: {fileID: -1323775644, guid: 30a885ca62e87834da7c2ea4faf0bb07, type: 3}
    speakerName: "G\xF6kb\xF6r\xFC"
  - text: "*(Ma\u011Faran\u0131n i\xE7inden k\u0131rm\u0131z\u0131 bir \u0131\u015F\u0131k
      yay\u0131l\u0131r.)*"
