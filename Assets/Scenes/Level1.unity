--- !u!114 &654111706
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 654111704}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b83a42f8f29be63479ff24c6194bf230, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogue
  conversation:
  - text: "Demek Ergenekon\u2019un son umudu sensin\u2026"
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan
  - text: "Ben sadece halk\u0131m\u0131 kurtarmaya geldim."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Kurtarmak m\u0131?\nY\u0131llard\u0131r burada \xE7\xFCr\xFCyorlar. \xC7\xFCnk\xFC
      zay\u0131flar."
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan (alay ederek)
  - text: "Hay\u0131r. \xC7\xFCnk\xFC sen onlar\u0131 korkuyla zincirledin."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Korku g\xFC\xE7t\xFCr, \xE7ocuk. G\xFC\xE7l\xFC olan y\xF6netir."
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan
  - text: "*(Rua birka\xE7 ad\u0131m yakla\u015F\u0131r.)*"
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Ger\xE7ek liderler korkuyla de\u011Fil, umutla y\xF6netir."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Umut mu? Umut insanlar\u0131 hayal k\u0131r\u0131kl\u0131\u011F\u0131na
      s\xFCr\xFCkler."
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: "Odkan (g\xFClerek)"
  - text: "Ama aya\u011Fa da kald\u0131r\u0131r."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Sen beni yenebilece\u011Fini san\u0131yorsun?"
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan
  - text: "Denemeden \xF6\u011Frenemem."
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "Cesursun\u2026 ama aptalca cesur."
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan
  - text: Belki. Ama senden korkmuyorum.
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  - text: "O halde zek\xE2na g\xFCveniyorsan\u2026 bir bilmece oyunu oynayal\u0131m."
    portrait: {fileID: -8357584540199660141, guid: 1e51683be44586545bb2b63196a2b41e, type: 3}
    speakerName: Odkan
  - text: Kabul ediyorum.**
    portrait: {fileID: -1336964543194316448, guid: dcacd733b0d473047a392186bc43b1f6, type: 3}
    speakerName: Rua
  onDialogueEnd:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 733103975}
        m_TargetAssemblyTypeName: MiniGameLauncher, Assembly-CSharp
        m_MethodName: LaunchGame
        m_Mode: 3
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 0
        m_CallState: 2
