  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogue
  conversation:
  - text: "Neden yaln\u0131z yemek yiyorsun? "
    portrait: {fileID: 4806233126341278129, guid: b4515ba62d2a9ab46a9506bfd2ae340c, type: 3}
    speakerName: Yeliz
  - text: "Um.. Yani \xE7evremde pek sevilmiyorum san\u0131r\u0131m, ailem yok diye...\n"
    portrait: {fileID: 1565856180230272299, guid: 879d1ec918a39254f8c381218798ff84, type: 3}
    speakerName: Nicholas
  - text: "Bence onlar senin de\u011Ferini bilmiyor. Bizimle tak\u0131lmaya ne dersin?\n"
    portrait: {fileID: 4806233126341278129, guid: b4515ba62d2a9ab46a9506bfd2ae340c, type: 3}
    speakerName: Yeliz
  onDialogueEnd:
